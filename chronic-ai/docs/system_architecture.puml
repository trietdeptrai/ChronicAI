@startuml
title ChronicAI - High-Level System Architecture (Container View)
left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam rectangle {
  RoundCorner 10
}
skinparam component {
  RoundCorner 10
}
skinparam ArrowColor #3d4a59
skinparam ArrowThickness 1

actor "Doctor" as Doctor
actor "Patient" as Patient

rectangle "Client Tier" as ClientTier #EAF3FF {
  component "Web Client\nNext.js 16 + React 19\n(TanStack Query, SSE consumer)" as FE
}

rectangle "ChronicAI Backend Tier (FastAPI)" as BackendTier #EEFBEF {
  component "API Gateway\nRouters:\n/chat, /upload, /doctor, /appointments" as API
  component "Chat Orchestration\nLangGraph (doctor_graph, patient_graph)\nHITL + streaming stages" as ORCH
  component "Clinical AI Services\nLLM calls, verification, safety checks\nresilience + in-memory cache" as CLIN
  component "Record Ingestion Pipeline\nFile upload, OCR, ECG classifier,\nrecord analysis" as INGEST
  component "RAG Service\nchunking + embeddings\ncontext retrieval" as RAG
  component "Chat History Service\nconversation/message persistence" as HIST
  component "Local Runtime State\nMemorySaver checkpoints,\n/tmp chat images" as LOCAL
}

rectangle "Data Tier (Supabase)" as DataTier #FFF7E8 {
  database "Postgres\npatients, doctors, medical_records,\nvital_signs, consultations,\nappointments, chat_*" as DB
  collections "Storage Bucket\npatient-photos / records/*" as ST
  database "pgvector + RPC\nsearch_patient_records(...)" as VEC
}

cloud "External AI Services" as ExternalAI #F4F0FF {
  component "Vertex AI Endpoint (default)\nchat/completions\n(+ Gemini embeddings optional)" as VERTEX
  component "Ollama (optional fallback)\nLLM + embedding APIs" as OLLAMA
  component "Hugging Face Hub (optional)\nMedSigLIP model download" as HF
}

Doctor --> FE : HTTPS
Patient --> FE : HTTPS

FE --> API : HTTP/JSON\nMultipart uploads\nSSE streams

API --> ORCH
API --> INGEST
API --> HIST
API --> DB : CRUD (doctor/patient/\nappointments/records/vitals)
API --> ST : upload/download\nsigned URLs

ORCH --> RAG : patient context
ORCH --> CLIN : reasoning + safety
ORCH --> LOCAL : thread state/checkpoints

INGEST --> CLIN : analyze record
INGEST --> RAG : ingest_document()
INGEST --> LOCAL : temp files + OCR + ECG
INGEST ..> HF : model fetch on first load

RAG --> DB : record_embeddings CRUD
RAG --> VEC : similarity RPC
HIST --> DB : chat_conversations + chat_messages

CLIN --> VERTEX : HTTPS + bearer token\n(gcloud access token flow)
CLIN ..> OLLAMA : HTTP (if LLM_PROVIDER=ollama)
RAG ..> VERTEX : Gemini embedding API\n(if EMBEDDING_PROVIDER=gemini)
RAG ..> OLLAMA : embedding API\n(if EMBEDDING_PROVIDER=ollama)

note bottom
Solid arrows = primary/default flow
Dashed arrows = optional or configuration-dependent flow
end note
@enduml
