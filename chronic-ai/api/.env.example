# -----------------------------------------------------------------------------
# ChronicAI API - Environment Template
# Copy to .env and fill values for your environment.
# -----------------------------------------------------------------------------

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
PATIENT_PHOTO_BUCKET=patient-photos
PATIENT_PHOTO_SIGNED_URL_TTL_SECONDS=3600

# App
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
CORS_ORIGINS=["http://localhost:3000"]

# LLM Provider
LLM_PROVIDER=vertex

# Vertex AI (OpenAI-compatible endpoint mode)
# Recommended host format: https://<location>-aiplatform.googleapis.com
VERTEX_AI_HOST=https://us-central1-aiplatform.googleapis.com
VERTEX_AI_PROJECT_ID=
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_ENDPOINT_ID=
VERTEX_AI_MODEL=
# Optional override if you need a custom full path
VERTEX_AI_CHAT_COMPLETIONS_PATH=
VERTEX_AI_GCLOUD_COMMAND=gcloud
VERTEX_AI_TOKEN_TTL_SECONDS=3300
VERTEX_AI_TEMPERATURE=0.2

# OpenAI-compatible endpoint (example: Featherless)
# Set LLM_PROVIDER=openai_compatible to use this route
# Example base URL: https://api.featherless.ai/v1
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_CHAT_COMPLETIONS_PATH=/chat/completions
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=
OPENAI_COMPATIBLE_TEMPERATURE=0.2

# Models
MEDICAL_MODEL=
VERIFICATION_MODEL=
# Optional dedicated model for upload image/file analysis.
# If empty, upload analysis uses MEDICAL_MODEL.
# For Featherless example:
# UPLOAD_ANALYSIS_MODEL=unsloth/medgemma-1.5-4b-it
UPLOAD_ANALYSIS_MODEL=
HF_TOKEN=
# ECG Classifier Remote Endpoint
ECG_CLASSIFIER_ENDPOINT_URL=
ECG_CLASSIFIER_ENDPOINT_TIMEOUT=60
# Auth type: none | bearer | api_key | vertex_gcloud
#   none          — no auth (local dev, VPN-protected)
#   bearer        — static token via ECG_CLASSIFIER_BEARER_TOKEN
#   api_key       — header+key via ECG_CLASSIFIER_API_KEY
#   vertex_gcloud — gcloud access token (default)
ECG_CLASSIFIER_AUTH_TYPE=vertex_gcloud
ECG_CLASSIFIER_BEARER_TOKEN=
ECG_CLASSIFIER_API_KEY=
ECG_CLASSIFIER_API_KEY_HEADER=X-API-Key
DOCTOR_REASONING_MAX_TOKENS=1400
VERIFICATION_MAX_TOKENS=256

# Embeddings
# hash (local deterministic vectors) | ollama | gemini
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=768
# Gemini embeddings (used when EMBEDDING_PROVIDER=gemini)
# If GEMINI_API_KEY is empty, backend falls back to Vertex Gemini settings.
GEMINI_API_KEY=
GEMINI_EMBEDDING_API_BASE=https://generativelanguage.googleapis.com
GEMINI_EMBEDDING_API_VERSION=v1beta
# Recommended model: gemini-embedding-001
EMBEDDING_TASK_TYPE_DOCUMENT=RETRIEVAL_DOCUMENT
EMBEDDING_TASK_TYPE_QUERY=RETRIEVAL_QUERY

# Upload pipeline
IMAGE_UPLOAD_RUN_OCR=false
IMPORT_PDF_OCR_DPI=140
IMPORT_PDF_OCR_MAX_PAGES=25
IMPORT_METADATA_PDF_OCR_MAX_PAGES=3
IMPORT_PDF_OCR_PREPROCESS=false
IMPORT_PDF_RENDER_THREADS=2

# HITL / Safety
ENABLE_HITL=true
HITL_CONFIDENCE_THRESHOLD=0.7
HITL_SAFETY_THRESHOLD=0.8
SAFETY_AUTO_ESCALATE_EMERGENCY=true
SAFETY_REQUIRE_CONTEXT=true
SAFETY_MAX_RISK_FACTORS=3

# Resilience
LLM_RETRY_MAX_ATTEMPTS=3
LLM_RETRY_BASE_DELAY=1.0
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60.0

PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK = True
