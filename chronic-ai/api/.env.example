# -----------------------------------------------------------------------------
# ChronicAI API - Environment Template
# Copy to .env and fill values for your environment.
# -----------------------------------------------------------------------------

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
PATIENT_PHOTO_BUCKET=patient-photos
PATIENT_PHOTO_SIGNED_URL_TTL_SECONDS=3600

# App
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
CORS_ORIGINS=["http://localhost:3000"]

# LLM Provider
# vertex | ollama
LLM_PROVIDER=vertex

# Vertex AI (OpenAI-compatible endpoint mode)
VERTEX_AI_HOST=
VERTEX_AI_PROJECT_ID=
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_ENDPOINT_ID=
VERTEX_AI_MODEL=
# Optional override if you need a custom full path
VERTEX_AI_CHAT_COMPLETIONS_PATH=
VERTEX_AI_GCLOUD_COMMAND=gcloud
VERTEX_AI_TOKEN_TTL_SECONDS=3300
VERTEX_AI_TEMPERATURE=0.2

# Ollama fallback (optional)
OLLAMA_HOST=http://localhost:11434
OLLAMA_AUTO_PULL_MISSING_MODELS=true

# Models
MEDICAL_MODEL=
VERIFICATION_MODEL=

# Embeddings
# hash (local deterministic vectors) | ollama
EMBEDDING_PROVIDER=hash
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768

# Upload pipeline
IMAGE_UPLOAD_RUN_OCR=false

# Translation
VINAI_VI2EN_MODEL=vinai/vinai-translate-vi2en
VINAI_EN2VI_MODEL=vinai/vinai-translate-en2vi
TRANSLATION_DEVICE=auto
TRANSLATION_CACHE_ENABLED=true
TRANSLATION_CACHE_MAX_SIZE=2000
TRANSLATION_CACHE_TTL=7200
TRANSLATION_BATCH_SIZE=8
TRANSLATION_ADAPTIVE_BEAMS=true
TRANSLATION_SHORT_TEXT_THRESHOLD=50

# HITL / Safety
ENABLE_HITL=true
HITL_CONFIDENCE_THRESHOLD=0.7
HITL_SAFETY_THRESHOLD=0.8
SAFETY_AUTO_ESCALATE_EMERGENCY=true
SAFETY_REQUIRE_CONTEXT=true
SAFETY_MAX_RISK_FACTORS=3

# Resilience
LLM_RETRY_MAX_ATTEMPTS=3
LLM_RETRY_BASE_DELAY=1.0
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60.0
