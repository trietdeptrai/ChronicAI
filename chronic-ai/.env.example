# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434

# Application Configuration
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Optional: API Keys for future enhancements
# OPENAI_API_KEY=your_openai_key

# LLM provider (vertex | openai_compatible | ollama)
LLM_PROVIDER=vertex

# OpenAI-compatible endpoint (example: Featherless)
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_CHAT_COMPLETIONS_PATH=/chat/completions
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=
OPENAI_COMPATIBLE_TEMPERATURE=0.2
OPENAI_COMPATIBLE_TIMEOUT_SECONDS=70
OPENAI_COMPATIBLE_CONNECT_TIMEOUT_SECONDS=15
OPENAI_COMPATIBLE_FALLBACK_MAX_TOKENS=700

# Retry behavior for graph reasoning
LLM_RETRY_MAX_ATTEMPTS=3
LLM_RETRY_BASE_DELAY=1.0

# Vertex AI auth (Render-safe setup)
# Recommended for deployment:
# VERTEX_AI_AUTH_METHOD=adc
# VERTEX_AI_SERVICE_ACCOUNT_JSON_BASE64=base64_of_service_account_json
# or:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
